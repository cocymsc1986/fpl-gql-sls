{
  "name": "fpl-gql-sls",
  "version": "1.0.0",
  "description": "AppSync GQL API",
  "main": "index.js",
  "scripts": {
    "test": "jest ./",
    "generate": "graphql-codegen",
    "type-check": "tsc -noEmit",
    "build": "rm -rf dist && esbuild ./src/* --entry-names=[dir]/[name]/index --bundle --minify --sourcemap --platform=node --target=node20 --outdir=dist"
